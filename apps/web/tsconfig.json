{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": false,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@painel/connectors": ["../../packages/connectors/src/index.ts"],
      "@painel/connectors/*": ["../../packages/connectors/src/*"],
      "@painel/jobs": ["../../packages/jobs/src/index.ts"],
      "@painel/jobs/*": ["../../packages/jobs/src/*"],
      "@painel/shared": ["../../packages/shared/src/index.ts"],
      "@painel/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
