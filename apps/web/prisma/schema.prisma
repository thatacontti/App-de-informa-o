// Painel V27 · Prisma schema
// Placeholder for step 1 (scaffold). Full domain model lands in step 3.
// Models referenced by future steps: User, AuditLog, DataSource, SyncRun,
// Sale, Customer, City, UF, Representative, Target, BriefingSnapshot.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- placeholder ----
// One model so `prisma generate` succeeds during scaffold;
// gets replaced by the full schema in step 3.
model HealthCheck {
  id        String   @id @default(cuid())
  ok        Boolean  @default(true)
  createdAt DateTime @default(now())
}
