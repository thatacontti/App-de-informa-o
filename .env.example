# =====================================================
# Painel V27 · Grupo Catarina — Environment template
# Copy to .env and fill in values. dotenv-safe blocks
# startup if any required key here is missing in .env.
# =====================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
PUBLIC_BASE_PATH=/painel/v27

# --- Auth (NextAuth / Auth.js) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# --- Database ---
DATABASE_URL=postgresql://painel:painel@postgres:5432/painel_v27?schema=public

# --- Redis (BullMQ + rate limit) ---
REDIS_URL=redis://redis:6379

# --- Connectors switch ---
# When true, connectors load the painel_v27/*.json fixtures
# instead of hitting real ERP / CRM / SharePoint.
USE_MOCK_CONNECTORS=true

# --- ERP Postgres (real mode) ---
ERP_DB_URL=postgresql://user:pass@srv-erp.catarina.local:5432/vendas
ERP_SYNC_INTERVAL_MINUTES=5

# --- CRM REST API (real mode) ---
CRM_BASE_URL=https://api.crm-catarina.com/v2
CRM_TOKEN=replace-me
CRM_SYNC_INTERVAL_MINUTES=5

# --- SharePoint XLSX (real mode, MS Graph client credentials) ---
SHAREPOINT_TENANT_ID=replace-me
SHAREPOINT_CLIENT_ID=replace-me
SHAREPOINT_CLIENT_SECRET=replace-me
SHAREPOINT_FILE_PATH=/Diretoria/Metas/V27.xlsx

# --- Notifications ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@catarina.local
SMTP_PASS=replace-me
SMTP_FROM=painel@catarina.local

SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_CHANNEL_DIRETORIA=#diretoria-comercial
SLACK_CHANNEL_ALERTS=#alertas-painel-v27

# --- SSO (phase 2 — leave blank for phase 1) ---
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Logs ---
LOG_LEVEL=info
